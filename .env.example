# 数据库配置
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sc_cloud
DB_PORT=5432
# 本地开发：app 跑在宿主机，连 docker-compose 暴露到 localhost 的 postgres
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}?schema=public&connect_timeout=10&pool_timeout=10"

# NextAuth v5 配置
# 生产环境改为实际域名
NEXTAUTH_URL="http://localhost:3000"
# 必填。生成随机密钥：openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# 应用端口
APP_PORT=3000

# 多模态识别（M3，实验记录图片 → 结构化字段；直连 MiniMax，不经 Vercel Gateway）
# MINIMAX_API_KEY 必填（境内站 api.minimaxi.com，Bearer）；其余可选、留默认即可
MINIMAX_API_KEY="sk-..."
# 默认 https://api.minimaxi.com/v1（境内带 i）；境外站为 https://api.minimax.io/v1
MINIMAX_BASE_URL="https://api.minimaxi.com/v1"
# 识别模型（不写死，便于将来换模型/供应商）。实测 MiniMax-M3 支持视觉
AI_OCR_MODEL="MiniMax-M3"
# 多模态开关：设 0 关闭（隐藏上传入口、走纯手工）；缺 MINIMAX_API_KEY 时亦自动关闭
MULTIMODAL_ENABLED=1

# 实验记录原图本地磁盘存证目录（私有，经鉴权代理读）。Docker 自托管挂持久卷
STORAGE_DIR="./storage"

# 生信系统产出指标机对机上报令牌（POST /api/integrations/run-metrics）。
# 未配置则该集成关闭（接口返回 503）。请求头 Authorization: Bearer <key> 或 X-Api-Key: <key>
INTEGRATION_API_KEY="change-me-integration-token"

# 邮件任务提醒（生信任务指派时通知分析负责人，重构 §6.5）
# 总开关：NOTIFY_ENABLED=1 才启用；关时全链路 no-op
NOTIFY_ENABLED=0
# SMTP 通道（境内企业邮箱/内网）；未配置 SMTP_HOST 时 dev 回退仅日志、不真发
SMTP_HOST=""
SMTP_PORT=587
# SMTP_SECURE=1 强制 TLS（465 端口）；否则按端口推断
SMTP_SECURE=0
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="no-reply@sc-cloud.local"
# 邮件正文里平台链接前缀（如 https://sc.example.com）；留空则用相对路径
APP_BASE_URL=""

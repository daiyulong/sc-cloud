# 数据库配置
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sc_cloud
DB_PORT=5432
# 本地开发：app 跑在宿主机，连 docker-compose 暴露到 localhost 的 postgres
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}?schema=public&connect_timeout=10&pool_timeout=10"

# NextAuth v5 配置
# 生产环境改为实际域名
NEXTAUTH_URL="http://localhost:3000"
# 必填。生成随机密钥：openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# 应用端口
APP_PORT=3000
